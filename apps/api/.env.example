# DEV_FALLBACK_USER_ID=u1

# POST /currency/fx (mutación global): header x-fx-upsert-secret debe coincidir
# FX_UPSERT_SECRET=genera-un-secreto-largo

# Cron deudas: POST /debts/internal/run-monthly-amortization con header x-cron-secret
# CRON_SECRET=otro-secreto-largo
