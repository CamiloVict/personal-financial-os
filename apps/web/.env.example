# Copia a `.env.local` y ajusta. Next.js solo expone al navegador variables con prefijo NEXT_PUBLIC_.

# URL del API NestJS (rewrite en Next y llamadas server-side). Por defecto 127.0.0.1:3001.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
# Opcional: URL solo en servidor (Docker: http://api:8080). Si no existe, se usa NEXT_PUBLIC_API_URL.
# INTERNAL_API_URL=http://api:8080
# Forzar llamadas directas al Nest desde el navegador (sin proxy /api/nest). Útil si CORS ya está resuelto.
# NEXT_PUBLIC_API_DIRECT=true

# Clerk (dashboard https://dashboard.clerk.com). Sin estas claves el middleware no protege rutas y no hay UI de sesión.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_d2hvbGUtd29tYmF0LTM5LmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_BmKivYH0yNlFlnFwD4oIG5avA2mf7oxxQ0Pd6uLgA3

# Opcional: solo para desarrollo sin Clerk (barra de sesión manual + API con AUTH_DISABLED)
NEXT_PUBLIC_DEFAULT_USER_ID=u1
