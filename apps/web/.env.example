# Copia a `.env.local` y ajusta. Next.js solo expone al navegador variables con prefijo NEXT_PUBLIC_.

# URL del API NestJS (por defecto en código: http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Debe coincidir con un usuario real en la tabla `User` (el seed crea id `u1`).
NEXT_PUBLIC_DEFAULT_USER_ID=u1
